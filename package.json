{
  "name": "the-cap-room",
  "version": "0.1.0",
  "private": true,
  "description": "THE CAP ROOM — a front-office console for NBA roster construction under the 2023 CBA. Unofficial demo, not affiliated with the Sacramento Kings or the NBA.",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run validate:data",
    "build": "next build",
    "validate:data": "tsx scripts/validate-data.ts",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.1.9"
  }
}
